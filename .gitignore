# 排除所有 .zip 和 .npz 文件 (比如你的数据集压缩包)
*.zip
*.npz

# 排除所有 .csv 或 .json .root文件 (如果是纯数据)
*.csv
*.json
*.root

# 排除特定的文件夹 (比如 data 文件夹)
data/
dataset/
checkpoints/

# 排除模型权重文件 (通常很大)
*.pt
*.pth
*.bin
*.h5
*.xml

# 排除临时文件或系统文件
.DS_Store
Thumbs.db
*.log

# ==========================================
# 你的原有配置 (保留即可)
# ==========================================
*.zip
*.npz
*.csv
*.json
*.root
data/
dataset/
checkpoints/
*.pt
*.pth
*.bin
*.h5
.DS_Store
Thumbs.db
*.log

# ==========================================
# 建议补充：Python 与 虚拟环境
# ==========================================
# 虚拟环境 (venv, conda, virtualenv)
venv/
env/
ENV/
.venv/
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebook 检查点 (不想上传每次自动保存的临时副本)
.ipynb_checkpoints/

# ==========================================
# 建议补充：编译产物与临时文件 (针对你的 TMVA/C++ 背景)
# ==========================================
# 编译产生的临时文件
*.so
*.o
*.class.C  <-- 这个就是你之前报错里提到的文件类型
*.class
*.dic

# 临时目录
tmp/
temp/

# ==========================================
# 建议补充：IDE 与 编辑器
# ==========================================
# VS Code
.vscode/
# PyCharm / IntelliJ
.idea/
*.iml

# ==========================================
# 建议补充：敏感信息 (安全红线)
# ==========================================
# 环境变量文件 (如果包含密码或 API Key)
.env
*.local